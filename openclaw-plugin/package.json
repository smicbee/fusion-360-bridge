{
  "name": "@smicbee/fusion-360-bridge-plugin",
  "version": "0.1.0",
  "description": "OpenClaw plugin for controlling Fusion 360 through the FusionBridge add-in",
  "type": "module",
  "license": "MIT",
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "README.md"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
